{
  "name": "msgsync",
  "version": "1.0.0",
  "description": "A powerful SMS platform for seamless message synchronization and delivery",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:platform": "pnpm --filter @msgsync/platform run dev",
    "dev:aggregator": "pnpm --filter @msgsync/aggregator run dev",
    "dev:www": "pnpm --filter @msgsync/www run dev",
    "start": "pnpm -r --parallel run start",
    "bootstrap:env": "node scripts/bootstrap-env.js",
    "check:stack": "node scripts/check-local-stack.js",
    "test": "pnpm -r --if-present run test",
    "test:smoke": "jest --runInBand packages/platform/tests/bootstrap-env.test.js",
    "test:ci": "pnpm -r --if-present run test -- --passWithNoTests",
    "test:coverage": "pnpm -r --if-present run test -- --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "pnpm -r run build",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "prisma:generate": "pnpm -r --if-present run prisma:generate",
    "prisma:migrate": "pnpm -r --if-present run prisma:migrate",
    "clean": "pnpm -r exec rm -rf node_modules"
  },
  "keywords": [
    "sms",
    "messaging",
    "sync",
    "platform",
    "aggregator",
    "sdk"
  ],
  "author": "MsgSync Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MsgSync/MsgSync.git"
  },
  "bugs": {
    "url": "https://github.com/MsgSync/MsgSync/issues"
  },
  "homepage": "https://github.com/MsgSync/MsgSync#readme",
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "catalog": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.38",
    "tsx": "^4.16.2",
    "@typescript/native": "^5.6.2",
    "zod": "^3.23.8",
    "recharts": "^2.12.0",
    "@tanstack/react-table": "^8.20.0",
    "next-themes": "^0.3.0",
    "lodash": "^4.17.21",
    "radix-ui": "^1.1.0",
    "@vitest/coverage-v8": "^2.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
}